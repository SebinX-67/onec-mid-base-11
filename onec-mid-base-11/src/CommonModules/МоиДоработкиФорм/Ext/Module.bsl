
// Начало. Кипаев – доработка форм документов
Процедура ПриСозданииНаСервере(Форма) Экспорт
    ИмяФормы = Форма.ИмяФормы;
    
    Если ИмяФормы = "Документ.ЗаказПокупателя.Форма.ФормаДокумента" Тогда
        // Для заказа покупателя добавляем и контактное лицо, и скидку
        ДобавитьПолеКонтактноеЛицоВГруппуШапкаПраво(Форма);
        ДобавитьПолеСкидкиИКнопку(Форма);
        
    ИначеЕсли ИмяФормы = "Документ.ПоступлениеТоваровУслуг.Форма.ФормаДокумента"
              Или ИмяФормы = "Документ.РеализацияТоваровУслуг.Форма.ФормаДокумента" Тогда
        ДобавитьПолеКонтактноеЛицоВГруппуШапкаПраво(Форма);
        
    ИначеЕсли ИмяФормы = "Документ.ОплатаОтПокупателя.Форма.ФормаДокумента"
              Или ИмяФормы = "Документ.ОплатаПоставщику.Форма.ФормаДокумента" Тогда
        ДобавитьПолеКонтактноеЛицоПередСуммой(Форма);
        
    КонецЕсли;
КонецПроцедуры

Процедура ДобавитьПолеКонтактноеЛицоВГруппуШапкаПраво(Форма)
    Родитель = Форма.Элементы.Найти("ГруппаШапкаПраво");
    Если Родитель = Неопределено Тогда
        Родитель = Форма.Элементы.Найти("ГруппаКолонкиШапки");
    КонецЕсли;
    Если Родитель = Неопределено Тогда Возврат; КонецЕсли;
    
    // Проверяем, не добавлено ли уже поле
    Если Форма.Элементы.Найти("КонтактноеЛицо") <> Неопределено Тогда Возврат; КонецЕсли;
    
    Поле = Форма.Элементы.Добавить("КонтактноеЛицо", Тип("ПолеФормы"), Родитель);
    Поле.Вид = ВидПоляФормы.ПолеВвода;
    Поле.ПутьКДанным = "Объект.КонтактноеЛицо";
    Поле.Заголовок = "Контактное лицо";
    Поле.Подсказка = "Выберите контактное лицо из справочника";
КонецПроцедуры

Процедура ДобавитьПолеКонтактноеЛицоПередСуммой(Форма)
    СуммаПоле = Форма.Элементы.Найти("СуммаДокумента");
    Если СуммаПоле = Неопределено Тогда Возврат; КонецЕсли;
    
    Если Форма.Элементы.Найти("КонтактноеЛицо") <> Неопределено Тогда Возврат; КонецЕсли;
    
    Поле = Форма.Элементы.Вставить("КонтактноеЛицо", Тип("ПолеФормы"), СуммаПоле);
    Поле.Вид = ВидПоляФормы.ПолеВвода;
    Поле.ПутьКДанным = "Объект.КонтактноеЛицо";
    Поле.Заголовок = "Контактное лицо";
КонецПроцедуры   


Процедура ДобавитьПолеСкидкиИКнопку(Форма)
    Родитель = Форма.Элементы.Найти("ГруппаШапкаЛево");
    Если Родитель = Неопределено Тогда
        Родитель = Форма.Элементы.Найти("ГруппаКолонкиШапки");
    КонецЕсли;
    Если Родитель = Неопределено Тогда Возврат; КонецЕсли;
    
    // Поле скидки
    ПолеСкидки = Форма.Элементы.Добавить("СогласованнаяСкидка", Тип("ПолеФормы"), Родитель);
    ПолеСкидки.Вид = ВидПоляФормы.ПолеВвода;
    ПолеСкидки.ПутьКДанным = "Объект.СогласованнаяСкидка";
    ПолеСкидки.Заголовок = "Согласованная скидка";
    ПолеСкидки.Подсказка = "Процент скидки (0-100)";
    ПолеСкидки.УстановитьДействие("ПриИзменении", "СогласованнаяСкидкаПриИзменении");   // <-- добавлено
    
    // Кнопка
    Кнопка = Форма.Элементы.Добавить("ПересчитатьТаблицы", Тип("КнопкаФормы"), Родитель);
    Кнопка.Заголовок = "Пересчитать таблицы";
    Кнопка.ИмяКоманды = "ПересчитатьТаблицыКоманда";
КонецПроцедуры
// Конец. Кипаев 