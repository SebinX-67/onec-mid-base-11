КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьТаблицыКоманда(Команда)
	  ПересчитатьВсеСтроки();
  КонецПроцедуры
  
&НаКлиенте
Процедура СогласованнаяСкидкаПриИзменении(Элемент)

    // Начало. Кипаев – обработка изменения согласованной скидки


    // Проверяем, есть ли заполненные табличные части через Количество()
    ЕстьДанные = Объект.Товары.Количество() > 0 ИЛИ Объект.Услуги.Количество() > 0;

    Если ЕстьДанные Тогда
        // Асинхронный вопрос
        Опов = Новый ОписаниеОповещения("ПослеВопросаОПересчете", ЭтотОбъект);
        ПоказатьВопрос(Опов, "Пересчитать суммы в табличных частях с учетом новой скидки?", РежимДиалогаВопрос.ДаНет);
    КонецЕсли;
    // Конец. Кипаев

КонецПроцедуры

&НаКлиенте
Процедура ПослеВопросаОПересчете(РезультатВопроса, ДополнительныеПараметры) Экспорт
    // Начало. Иванов – обработка результата вопроса
    Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
        ПересчитатьВсеСтроки();
    КонецЕсли;
    // Конец. Иванов
КонецПроцедуры


// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

