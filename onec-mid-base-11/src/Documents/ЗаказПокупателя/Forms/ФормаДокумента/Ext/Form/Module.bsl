#КонецОбласти

#Область СлужебныеПроцедурыИФункции


&НаКлиенте
&ИзменениеИКонтроль("РассчитатьСуммуСтроки")
Процедура РассчитатьСуммуСтроки(ТекущиеДанные)
    // Начало. Кипаев – учёт согласованной скидки при расчёте суммы строки
    // Исходный типовой код (сохранён для контроля):
    // ТекущиеДанные.Сумма = ТекущиеДанные.Цена * ТекущиеДанные.Количество;
    // РассчитатьСуммуДокумента();
    
    Скидка = Объект.СогласованнаяСкидка;
     ТекущиеДанные.Сумма = Окр(ТекущиеДанные.Количество * ТекущиеДанные.Цена * (1 - Скидка / 100), 2);
      
    РассчитатьСуммуДокумента();
    // Конец. Кипаев
КонецПроцедуры

&НаКлиенте
Процедура ПересчитатьВсеСтроки()
	// Начало. Кипаев – пересчёт всех строк табличных частей с учётом скидки
	Для Каждого СтрокаТовары Из Объект.Товары Цикл
		РассчитатьСуммуСтроки(СтрокаТовары);
	КонецЦикла;
	Для Каждого СтрокаУслуги Из Объект.Услуги Цикл
		РассчитатьСуммуСтроки(СтрокаУслуги);
	КонецЦикла;
	// Конец. Кипаев
КонецПроцедуры

&НаКлиенте
Процедура РассчитатьСуммуДокумента()
    Объект.СуммаДокумента = Объект.Товары.Итог("Сумма") + Объект.Услуги.Итог("Сумма");
КонецПроцедуры
#КонецОбласти

